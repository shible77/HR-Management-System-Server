# Copy this file to .env and fill in the values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string
DB_URL="postgresql://hrmsdb_owner:SEf1ClQJ6cxX@ep-shrill-mouse-a14lt9ri.ap-southeast-1.aws.neon.tech/hrmsdb?sslmode=verify-full"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Use a long random string in production, e.g.:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="hrms_secret_key"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your front-end origin — no trailing slash
CLIENT_URL="http://localhost:5173"

# ── Email (nodemailer / Gmail SMTP) ───────────────────────────────────────────
EMAIL="shible0805@gmail.com"
# Use a Gmail App Password, not your account password.
# Generate one at: https://myaccount.google.com/apppasswords
PASSWORD="wltbobyqpyrasbcn"

# ── Redis ─────────────────────────────────────────────────────────────────────
# When running via docker-compose, set REDIS_HOST to the service name "redis".
# For a managed Redis (e.g. Upstash, Railway), set the host and port accordingly.
REDIS_HOST="redis"
REDIS_PORT=6379
